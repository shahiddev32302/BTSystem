<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - OmniBus Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Tailwind Custom Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#135bec",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                        "surface-dark": "#1a2234",
                        "border-dark": "#2d3748"
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts + Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <!-- Dark Mode Auto Load -->
    <script>
        (function () {
            const theme = localStorage.getItem("theme") || "light";
            if (theme === "dark") {
                document.documentElement.classList.add("dark");
            }
        })();
    </script>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display transition-colors duration-300">

    <div class="flex h-screen overflow-hidden">

        <!-- SIDEBAR -->
        <aside class="w-64 bg-white dark:bg-surface-dark border-r border-slate-200 dark:border-border-dark hidden lg:flex flex-col">

            <!-- Logo -->
            <div class="p-6 flex items-center gap-3">
                <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
                    <span class="material-icons text-white">directions_bus</span>
                </div>
                <span class="text-xl font-bold tracking-tight text-slate-800 dark:text-white">
                    OmniBus
                    <span class="text-primary text-xs block font-normal -mt-1">
                        Super Admin
                    </span>
                </span>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-4 space-y-2 mt-4">

                <!-- Dashboard -->
                <a asp-controller="SuperAdmin" asp-action="Dashboard"
                   class="flex items-center gap-3 px-4 py-3 bg-primary text-white rounded-lg shadow-md">

                    <span class="material-icons text-[20px]">dashboard</span>
                    <span class="font-semibold">Dashboard</span>
                </a>

                <!-- Companies -->
                <a asp-controller="Company" asp-action="CompanyManagement"
                   class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition">

                    <span class="material-icons text-[20px]">business</span>
                    <span>Companies</span>
                </a>

                <!-- Admin Management -->
                <a asp-controller="AdminManagement" asp-action="Management"
                   class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition">

                    <span class="material-icons text-[20px]">admin_panel_settings</span>
                    <span>Admin Management</span>
                </a>

                <!-- Notifications -->
                <a asp-controller="SuperAdminNotification" asp-action="NotificationManagement"
                   class="flex items-center justify-between px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition">

                    <div class="flex items-center gap-3">
                        <span class="material-icons text-[20px]">notifications</span>
                        <span>Notifications</span>
                    </div>

                    <span class="min-w-[20px] h-5 px-1.5 text-[10px] font-bold flex items-center justify-center rounded-full bg-red-500 text-white">
                        3
                    </span>
                </a>

            </nav>

            <!-- Logout -->
            <div class="p-4 border-t border-slate-200 dark:border-border-dark">
                <a asp-controller="Account" asp-action="Logout"
                   class="flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 rounded-lg transition">

                    <span class="material-icons text-[20px]">logout</span>
                    <span>Logout</span>
                </a>
            </div>

        </aside>

        <!-- MAIN CONTENT -->
        <main class="flex-1 flex flex-col overflow-hidden">

            <!-- HEADER -->
            <header class="h-16 bg-white dark:bg-surface-dark border-b border-slate-200 dark:border-border-dark flex items-center justify-between px-8">

                <!-- Search -->
                <div class="relative w-full max-w-xl">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">
                        search
                    </span>
                    <input class="w-full pl-10 pr-4 py-2 bg-slate-50 dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary/50 text-sm"
                           placeholder="Search for companies, drivers, or students..." />
                </div>

                <!-- Right Section -->
                <div class="flex items-center gap-6">

                    <!-- System Status -->
                    <div class="hidden md:flex flex-col items-end">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                            System Status
                        </span>
                        <div class="flex items-center gap-2">
                            <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                            <span class="text-xs font-medium text-emerald-600 dark:text-emerald-400 uppercase">
                                Online
                            </span>
                        </div>
                    </div>

                    <!-- Dark Mode Toggle -->
                    <button onclick="toggleDarkMode()"
                            class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full">
                        <span class="material-icons">dark_mode</span>
                    </button>

                    <!-- Profile -->
                    <div class="flex items-center gap-3">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-semibold">Alex Rivera</p>
                            <p class="text-[10px] text-slate-500 dark:text-slate-400 uppercase font-bold">
                                Super Administrator
                            </p>
                        </div>
                        <img class="w-9 h-9 rounded-full object-cover border-2 border-primary/20"
                             src="https://i.pravatar.cc/100" />
                    </div>

                </div>

            </header>

            <!-- PAGE BODY -->
            <div class="flex-1 overflow-y-auto p-8">
                @RenderBody()
            </div>

        </main>

    </div>

    <!-- Dark Mode Toggle Script -->
    <script>
        function toggleDarkMode() {
            const html = document.documentElement;
            html.classList.toggle("dark");

            if (html.classList.contains("dark")) {
                localStorage.setItem("theme", "dark");
            } else {
                localStorage.setItem("theme", "light");
            }
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>