@{
    ViewData["Title"] = "Verify Code";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="w-full max-w-5xl bg-white dark:bg-bg-dark rounded-2xl shadow-2xl overflow-hidden">

    <div class="flex min-h-[600px]">

        <!-- LEFT PANEL -->
        <div class="hidden lg:flex w-5/12 bg-primary text-white relative p-16 flex-col justify-between">
            <div>
                <div class="flex items-center gap-3 mb-12">
                    <span class="material-symbols-outlined text-4xl">directions_bus</span>
                    <h2 class="text-2xl font-bold">OmniBus</h2>
                </div>

                <h1 class="text-5xl font-black leading-tight mb-6">
                    Verify<br>Your Code
                </h1>

                <p class="text-white/80 text-lg max-w-md">
                    We’ve sent a 6-digit verification code to your email.
                </p>
            </div>

            <p class="text-sm text-white/80">Secure verification process</p>

            <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
            <div class="absolute top-1/2 -right-24 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="w-full lg:w-7/12 flex items-center justify-center px-8 py-12 bg-white dark:bg-bg-dark"
             style="background-color: #1a1a1a;">

            <div class="w-full max-w-md space-y-8">

                <div>
                    <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
                        Enter Verification Code
                    </h2>
                    <p class="text-gray-500 dark:text-gray-400 mt-1">
                        Please enter the 6-digit code sent to your email
                    </p>
                </div>

                <!-- OTP FORM -->
                <form class="space-y-6">

                    <div class="flex justify-between gap-3" id="otpContainer">
                        <input maxlength="1" type="text" class="otp-input" />
                        <input maxlength="1" type="text" class="otp-input" />
                        <input maxlength="1" type="text" class="otp-input" />
                        <input maxlength="1" type="text" class="otp-input" />
                        <input maxlength="1" type="text" class="otp-input" />
                        <input maxlength="1" type="text" class="otp-input" />
                    </div>

                    <!-- Verify Button -->
                    <button type="button" id="verifyBtn"
                            class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-lg shadow-lg transition flex items-center justify-center gap-2 text-lg">
                        Verify Code
                        <span class="material-symbols-outlined">send</span>
                    </button>

                </form>

                <!-- Resend -->
                <p class="text-center text-sm text-gray-500 dark:text-gray-400">
                    Didn’t receive the code?
                    <a asp-action="ForgotPassword" asp-controller="Account" class="text-primary font-bold hover:underline">
                        Resend
                    </a>
                </p>

            </div>
        </div>
    </div>
</div>
@section Scripts {

    <script>

        const inputs = document.querySelectorAll(".otp-input");

        // Style apply
        inputs.forEach(input => {
            input.className = "otp-input w-12 h-14 text-center text-xl font-bold border rounded-lg focus:ring-2 focus:ring-primary outline-none dark:bg-gray-900 dark:border-gray-700 dark:text-white";
        });

        // Auto focus + number only
        inputs.forEach((input, index) => {

            input.addEventListener("input", (e) => {

                e.target.value = e.target.value.replace(/[^0-9]/g, '');

                if (e.target.value && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && !input.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });

        });

        // VERIFY BUTTON
        document.getElementById("verifyBtn").addEventListener("click", function () {

            let otp = "";
            inputs.forEach(input => otp += input.value);

            if (otp.length !== 6) {
                alert("Please enter complete 6-digit code");
                return;
            }
                    window.location.href = '@Url.Action("ResetPassword", "Account")';
            // fetch("https://yourapiurl.com/api/Auth/VerifyCode", {
            //     method: "POST",
            //     headers: {
            //         "Content-Type": "application/json"
            //     },
            //     body: JSON.stringify({
            //         code: otp
            //     })
            // })
            //     .then(response => {
            //         if (!response.ok) {
            //             throw new Error("Invalid Code");
            //         }
            //         return response.json();
            //     })
            //     .then(data => {

            //         // ✅ Redirect to Reset Password Page
            //         window.location.href = '@Url.Action("ResetPassword", "Account")';

            //     })
            //     .catch(error => {
            //         alert("Invalid or expired code");
            //         console.error(error);
            //     });

        });

    </script>

}