@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}
<!-- MAIN CARD -->
<div class="w-full max-w-6xl bg-white dark:bg-bg-dark rounded-2xl shadow-2xl overflow-hidden">

    <div class="flex min-h-[720px]">

        <!-- LEFT PANEL -->
        <div class="hidden lg:flex w-5/12 bg-primary text-white relative p-16 flex-col justify-between">
            <div>
                <div class="flex items-center gap-3 mb-12">
                    <span class="material-symbols-outlined text-4xl">directions_bus</span>
                    <h2 class="text-2xl font-bold">OmniBus</h2>
                </div>

                <h1 class="text-5xl font-black leading-tight mb-6">
                    Secure Your<br>Password
                </h1>

                <p class="text-white/80 text-lg max-w-md">
                    Create a new strong password to keep your account protected.
                </p>
            </div>

            <p class="text-sm text-white/80">Safe • Secure • Reliable</p>

            <!-- glow -->
            <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
            <div class="absolute top-1/2 -right-24 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
        </div>


        <!-- RIGHT PANEL -->
        <div class="w-full lg:w-7/12 flex items-center justify-center px-8 py-12 bg-white dark:bg-bg-dark"
             style="background-color: #1a1a1a;">
            <div class="w-full max-w-md space-y-8">

                <!-- Heading -->
                <div>
                    <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
                        Reset Password
                    </h2>
                    <p class="text-gray-500 dark:text-gray-400 mt-1">
                        Enter your new password below
                    </p>
                </div>

                <!-- FORM -->
                <form class="space-y-5">

                    <!-- New Password -->
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                            New Password
                        </label>
                        <div class="relative mt-1">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                                lock
                            </span>
                            <input type="password" id="newPassword" placeholder="••••••••"
                                   class="w-full pl-11 pr-4 py-3.5 border rounded-lg focus:ring-2 focus:ring-primary outline-none dark:bg-gray-900 dark:border-gray-700 dark:text-white">
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                            Confirm Password
                        </label>
                        <div class="relative mt-1">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                                lock_reset
                            </span>
                            <input type="password" id="confirmPassword" placeholder="••••••••"
                                   class="w-full pl-11 pr-4 py-3.5 border rounded-lg focus:ring-2 focus:ring-primary outline-none dark:bg-gray-900 dark:border-gray-700 dark:text-white">
                        </div>
                    </div>

                    <!-- Button -->
                    <div class="pt-4">
                        <button type="button" id="updatePasswordBtn"
                                class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-lg shadow-lg transition flex items-center justify-center gap-2 text-lg">
                            Update Password
                            <span class="material-symbols-outlined">check_circle</span>
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>


@section Scripts {

    <script>

        document.getElementById("updatePasswordBtn").addEventListener("click", function () {

            const newPassword = document.getElementById("newPassword").value;
            const confirmPassword = document.getElementById("confirmPassword").value;

            if (!newPassword || !confirmPassword) {
                alert("Please fill all fields");
                return;
            }

            if (newPassword.length < 6) {
                alert("Password must be at least 6 characters");
                return;
            }

            if (newPassword !== confirmPassword) {
                alert("Passwords do not match");
                return;
            }
            window.location.href = '@Url.Action("Login", "Account")';
            // fetch("https://yourapiurl.com/api/Auth/ResetPassword", {
