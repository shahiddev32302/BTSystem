            background: var(--primary);
            color: white;
        }

    .card-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        flex-wrap: wrap;
    }

        .card-actions .btn {
            flex: 1;
            min-width: 100px;
        }

    /* Manage Stops Modal */
    #manageStopsModal .modal-dialog {
        max-width: 560px;
    }

    #manageStopsModal .modal-content {
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(15, 23, 42, 0.08);
    }

    #manageStopsModal .input-group .form-control {
        border-radius: 12px 0 0 12px;
        border: 1px solid var(--border);
    }

    #manageStopsModal .input-group .btn {
        border-radius: 0 12px 12px 0;
    }

    #manageStopsModal .badge.bg-primary-light {
        background: rgba(37, 99, 235, 0.12);
        color: #2563eb;
        font-size: 0.75rem;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
    }

    .stops-container {
        display: grid;
        gap: 12px;
    }

    .stop-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px 16px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 14px;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    }

    .stop-content {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .stop-number {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--primary);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .stop-content span:last-child {
        display: block;
        color: var(--text-primary);
        font-size: 0.95rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .btn-remove-stop {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.32);
        background: transparent;
        color: var(--text-secondary);
        transition: all 0.2s ease;
    }

        .btn-remove-stop:hover {
