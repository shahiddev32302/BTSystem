<!-- Add Route Modal -->
<div class="modal fade" id="addRouteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Route</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Route Name</label>
                        <input type="text" class="form-control" placeholder="e.g., Campus Loop">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" placeholder="Route description"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Distance (km)</label>
                            <input type="number" class="form-control" placeholder="e.g., 8.5" step="0.1">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Duration (mins)</label>
                            <input type="number" class="form-control" placeholder="e.g., 25">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Starting Point</label>
                            <input type="text" class="form-control" placeholder="e.g., Campus Main Gate">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ending Point</label>
                            <input type="text" class="form-control" placeholder="e.g., City Center">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Route Status</label>
                        <select class="form-select">
                            <option value="active" selected>Active</option>
                            <option value="inactive">Inactive</option>
                            <option value="maintenance">Under Maintenance</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Add Route</button>
            </div>
        </div>
    </div>
</div>

<!-- Manage Stops Modal -->
<div class="modal fade" id="manageStopsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title text-primary">Manage Route Stops</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div class="mb-4">
                    <label class="form-label text-muted small text-uppercase fw-bold">Current Route</label>
                    <h4 id="currentRouteName" class="mb-0">--</h4>
                </div>

                <div class="mb-3">
                    <label class="form-label">Add New Stop</label>
                    <div class="input-group">
                        <input type="text" id="modalStopInput" class="form-control" placeholder="Enter stop name...">
                        <button class="btn btn-primary px-3" type="button" id="modalAddStopBtn">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
                    <label class="form-label mb-0">Route Timeline</label>
                    <span class="badge bg-primary-light" id="modalStopsCount">0 Stops</span>
                </div>

                <div id="modalStopsList" class="stops-container pb-3">
                    <div class="text-center py-4 text-muted border rounded-3" id="modalNoStopsMsg">
                        <i class="fas fa-map-markers-alt mb-2 d-block opacity-50 fs-4"></i>
                        No stops defined for this route yet
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pb-4 px-4">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary px-4">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filterTabs = document.querySelectorAll('.filter-tab');
            const routeWrappers = document.querySelectorAll('.route-card-wrapper');

            // Layout search input use kar rahe hain
            const searchInput = document.getElementById('globalSearchInput');

            function filterRoutes() {
                const activeTab = document.querySelector('.filter-tab.active');
                const status = activeTab ? activeTab.dataset.status : 'all';
                const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';

                routeWrappers.forEach(wrapper => {
                    const title = wrapper.querySelector('h5')?.textContent.toLowerCase() || '';
                    const desc = wrapper.querySelector('.route-desc')?.textContent.toLowerCase() || '';
                    const cardStatus = wrapper.dataset.status;

                    const matchesStatus = status === 'all' || cardStatus === status;
                    const matchesSearch = title.includes(searchTerm) || desc.includes(searchTerm);

                    wrapper.style.display = (matchesStatus && matchesSearch) ? '' : 'none';
                });
            }

            filterTabs.forEach(tab => {
                tab.addEventListener('click', function () {
                    filterTabs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');
                    filterRoutes();
                });
            });

            if (searchInput) {
                searchInput.addEventListener('input', filterRoutes);
            }

            // STOP MANAGEMENT LOGIC
            const modalStopsList = document.getElementById('modalStopsList');
            const modalStopInput = document.getElementById('modalStopInput');
            const modalAddStopBtn = document.getElementById('modalAddStopBtn');
            const modalStopsCount = document.getElementById('modalStopsCount');
            const modalNoStopsMsg = document.getElementById('modalNoStopsMsg');
            const currentRouteNameDisplay = document.getElementById('currentRouteName');

            let currentStops = [];

            document.querySelectorAll('.btn-manage-stops').forEach(btn => {
                btn.addEventListener('click', function () {
                    const routeCard = this.closest('.route-card');
                    const routeName = routeCard.querySelector('h5').textContent;
                    currentRouteNameDisplay.textContent = routeName;

                    currentStops = [];
                    renderModalStops();
                });
            });

            function renderModalStops() {
                modalStopsList.querySelectorAll('.stop-item').forEach(el => el.remove());

                if (currentStops.length === 0) {
                    modalNoStopsMsg.classList.remove('d-none');
                } else {
                    modalNoStopsMsg.classList.add('d-none');

                    currentStops.forEach((stop, index) => {
                        const stopItem = document.createElement('div');
                        stopItem.className = 'stop-item';
                        stopItem.innerHTML = `
                                    <div class="stop-content">
                                        <span class="stop-number">${index + 1}</span>
                                        <span>${stop}</span>
                                    </div>
                                    <button class="btn-remove-stop" data-index="${index}">
                                        <i class="fas fa-times"></i>
                                    </button>
                                `;
                        modalStopsList.appendChild(stopItem);
                    });
                }

                modalStopsCount.textContent = `${currentStops.length} Stops`;

                modalStopsList.querySelectorAll('.btn-remove-stop').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const index = parseInt(this.getAttribute('data-index'));
                        currentStops.splice(index, 1);
                        renderModalStops();
                    });
                });
            }

            modalAddStopBtn.addEventListener('click', function () {
                const stopName = modalStopInput.value.trim();
                if (stopName) {
                    currentStops.push(stopName);
                    modalStopInput.value = '';
                    renderModalStops();
                }
            });

            modalStopInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    modalAddStopBtn.click();
                }
            });
        });
    </script>
}