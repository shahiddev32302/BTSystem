@{
    ViewData["Title"] = "Admin Management";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- SweetAlert Z-Index Fix -->
<style>
    .swal2-container {
        z-index: 20000 !important;
    }
</style>

<!-- Dashboard Content -->
<div class="flex-1 overflow-y-auto p-8 space-y-8">
    <!-- Welcome Section -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight">Admin Management</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">
                Manage and monitor all system administrators and their permissions.
            </p>
        </div>
        <div class="flex items-center gap-3">
            <button id="addAdminBtn"
                    class="flex items-center gap-3 px-5 py-2.5 bg-primary text-white hover:bg-primary/90 rounded-xl transition-all text-sm font-semibold shadow-lg shadow-primary/25">
                <span class="material-icons text-[20px]">add</span>
                Add New Admin
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Total Admins</p>
                    <h3 id="totalAdmins" class="text-2xl font-bold mt-1">0</h3>
                    <p class="text-emerald-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">trending_up</span> +2 this month
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">admin_panel_settings</span>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Active</p>
                    <h3 id="activeAdmins" class="text-2xl font-bold mt-1">0</h3>
                    <p class="text-emerald-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">check_circle</span> 90% overall
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">verified_user</span>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Pending</p>
                    <h3 id="pendingAdmins" class="text-2xl font-bold mt-1">0</h3>
                    <p class="text-amber-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">hourglass_empty</span> Awaiting Review
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">how_to_reg</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter and Search Bar -->
    <div class="bg-white dark:bg-surface-dark p-4 rounded-xl border border-primary/5 shadow-sm flex flex-col sm:flex-row gap-4 justify-between items-center bg-slate-50/50 dark:bg-background-dark/30">
        <div class="relative w-full sm:w-96">
            <span class="material-icons absolute left-3 top-2.5 text-slate-400 text-sm">search</span>
            <input id="searchInput"
                   class="w-full bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-transparent"
                   placeholder="Search by admin name or email..." type="text" />
        </div>
        <div class="flex gap-2 w-full sm:w-auto">
            <select id="statusFilter"
                    class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none cursor-pointer">
                <option value="All">Status: All</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
                <option value="Pending">Pending</option>
            </select>
        </div>
    </div>

    <!-- Admins Table -->
    <div class="bg-white dark:bg-surface-dark rounded-xl border border-primary/5 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                        <th class="px-6 py-4">Admin Info</th>
                        <th class="px-6 py-4">Email Address</th>
                        <th class="px-6 py-4">Phone Number</th>
                        <th class="px-6 py-4">Company</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="adminTableBody" class="divide-y divide-primary/5"></tbody>
            </table>
        </div>
    </div>

    <!-- Add / Edit Admin Modal -->
    <div id="addAdminModal" class="fixed inset-0 z-[9999] hidden">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" id="modalBackdrop"></div>
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative w-full max-w-lg transform overflow-hidden rounded-2xl bg-white dark:bg-surface-dark p-8 shadow-2xl transition-all border border-slate-200 dark:border-border-dark">
                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                            <span class="material-icons text-primary">security</span>
                        </div>
                        <div>
                            <h3 id="modalTitle" class="text-xl font-bold">Add New Admin</h3>
                            <p id="modalSubtitle" class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                                Create a new system administrator
                            </p>
                        </div>
                    </div>
                    <button id="closeModalBtn"
                            class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                        <span class="material-icons">close</span>
                    </button>
                </div>

                <form id="addAdminForm" class="space-y-4">
                    <input type="hidden" id="editAdminId" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Username</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">alternate_email</span>
                                <input id="username" type="text" required
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="john.doe">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Full Name</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">person</span>
                                <input id="fullName" type="text" required
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="John Smith">
                            </div>
                        </div>

                        <div class="sm:col-span-2">
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Contact Email</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">email</span>
                                <input id="email" type="email" required
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="admin@omnibus.com">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Phone Number</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">phone</span>
                                <input id="phone" type="tel"
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="+92 300 1234567">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Select Company</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">business</span>
                                <select id="companyDropdown" required
                                        class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm appearance-none">
                                    <option value="">Select Company</option>
                                </select>
                            </div>
                        </div>

                        <!-- Password only for Add -->
                        <div id="passwordFieldWrapper">
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Password</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">lock</span>
                                <input id="password" type="password" minlength="8"
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="••••••••">
                            </div>
                        </div>

                        <div id="confirmPasswordFieldWrapper">
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Confirm Password</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">lock</span>
                                <input id="confirmPassword" type="password"
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm"
                                       placeholder="••••••••">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Status</label>
                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">info</span>
                                <select id="statusSelect"
                                        class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-sm appearance-none">
                                    <option value="0">Inactive</option>
                                    <option value="1" selected>Active</option>
                                    <option value="2">Pending</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-col sm:flex-row gap-3 pt-6 border-t border-slate-100 dark:border-border-dark">
                        <button type="button" id="cancelModalBtn"
                                class="flex-1 px-6 py-3 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-bold rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all text-sm">
                            Cancel
                        </button>
                        <button type="submit" id="submitAdminBtn"
                                class="flex-1 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 shadow-lg shadow-primary/25 transition-all text-sm flex items-center justify-center gap-2">
                            <span class="material-icons text-sm">check_circle</span>
                            Confirm & Create
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="flex flex-col md:flex-row justify-between items-center py-4 border-t border-slate-200 dark:border-border-dark text-slate-400 text-xs">
        <p>© 2024 OmniBus Tracking System. All rights reserved.</p>
        <div class="flex gap-6 mt-4 md:mt-0">
            <a class="hover:text-primary transition-colors" href="#">Privacy Policy</a>
            <a class="hover:text-primary transition-colors" href="#">Service Status</a>
            <a class="hover:text-primary transition-colors" href="#">API Docs</a>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // =========================
            // CONFIG
            // =========================
            const API_BASE = "http://192.168.10.189:8021";
            const MODIFIED_BY = 1;
            const CREATED_BY = 1;

            // =========================
            // ELEMENTS
            // =========================
            const modal = document.getElementById('addAdminModal');
            const addBtn = document.getElementById('addAdminBtn');
            const form = document.getElementById('addAdminForm');

            const closeBtns = [
                document.getElementById('closeModalBtn'),
                document.getElementById('cancelModalBtn'),
                document.getElementById('modalBackdrop')
            ];

            const modalTitle = document.getElementById("modalTitle");
            const modalSubtitle = document.getElementById("modalSubtitle");
            const submitBtn = document.getElementById("submitAdminBtn");

            const passwordFieldWrapper = document.getElementById("passwordFieldWrapper");
            const confirmPasswordFieldWrapper = document.getElementById("confirmPasswordFieldWrapper");

            const passwordInput = document.getElementById("password");
            const confirmPasswordInput = document.getElementById("confirmPassword");

            const searchInput = document.getElementById("searchInput");
            const statusFilter = document.getElementById("statusFilter");

            const tableBody = document.getElementById("adminTableBody");

            // =========================
            // STATE
            // =========================
            let isEditMode = false;
            let editingAdminId = null;
            let allAdmins = [];
            let searchTimeout = null;

            // =========================
            // MODAL FUNCTIONS
            // =========================
            function openModal() {
                modal.classList.remove('hidden');
                loadCompanies();
            }

            function closeModal() {
                modal.classList.add('hidden');
                resetForm();
            }

            function resetForm() {
                form.reset();
                isEditMode = false;
                editingAdminId = null;

                document.getElementById("editAdminId").value = "";

                modalTitle.innerText = "Add New Admin";
                modalSubtitle.innerText = "Create a new system administrator";
                submitBtn.innerHTML = `
                            <span class="material-icons text-sm">check_circle</span>
                            Confirm & Create
                        `;

                passwordFieldWrapper.style.display = "block";
                confirmPasswordFieldWrapper.style.display = "block";

                passwordInput.required = true;
                confirmPasswordInput.required = true;

                document.getElementById("statusSelect").value = "1";
            }

            function setEditMode(admin) {
                isEditMode = true;
                editingAdminId = admin.adminId;

                document.getElementById("editAdminId").value = admin.adminId;

                modalTitle.innerText = "Update Admin";
                modalSubtitle.innerText = "Modify administrator details";
                submitBtn.innerHTML = `
                            <span class="material-icons text-sm">edit</span>
                            Update Admin
                        `;

                document.getElementById("fullName").value = admin.fullName ?? "";
                document.getElementById("username").value = admin.username ?? "";
                document.getElementById("email").value = admin.email ?? "";
                document.getElementById("phone").value = admin.phone ?? "";

                passwordInput.value = "";
                confirmPasswordInput.value = "";

                passwordFieldWrapper.style.display = "none";
                confirmPasswordFieldWrapper.style.display = "none";

                passwordInput.required = false;
                confirmPasswordInput.required = false;

                openModal();

                setTimeout(() => {
                    document.getElementById("companyDropdown").value = admin.companyId ?? "";
                }, 400);

                if (admin.status === "Inactive") {
                    document.getElementById("statusSelect").value = "0";
                } else if (admin.status === "Pending") {
                    document.getElementById("statusSelect").value = "2";
                } else {
                    document.getElementById("statusSelect").value = "1";
                }
            }

            // =========================
            // ALERT HELPERS
            // =========================
            function showSuccess(message) {
                return Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: message,
                    confirmButtonColor: '#2563eb',
                    zIndex: 30000
                });
            }

            function showError(message) {
                return Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: message,
                    confirmButtonColor: '#dc2626',
                    zIndex: 30000
                });
            }

            function showWarning(message) {
                return Swal.fire({
                    icon: 'warning',
                    title: 'Warning',
                    text: message,
                    confirmButtonColor: '#f59e0b',
                    zIndex: 30000
                });
            }

            // =========================
            // EVENT BINDINGS
            // =========================
            if (addBtn) {
                addBtn.addEventListener('click', () => {
                    resetForm();
                    openModal();
                });
            }

            closeBtns.forEach(btn => {
                if (btn) btn.addEventListener('click', closeModal);
            });

            if (form) {
                form.addEventListener("submit", async function (e) {
                    e.preventDefault();

                    if (isEditMode) {
                        closeModal();

                        setTimeout(async () => {
                            const result = await Swal.fire({
                                title: 'Update Admin?',
                                text: 'Are you sure you want to update this admin?',
                                icon: 'question',
                                showCancelButton: true,
                                confirmButtonColor: '#2563eb',
                                cancelButtonColor: '#64748b',
                                confirmButtonText: 'Yes, Update',
                                zIndex: 30000
                            });

                            if (result.isConfirmed) {
                                updateAdmin();
                            } else {
                                openModal();
                            }
                        }, 150);

                    } else {
                        const password = passwordInput.value;
                        const confirmPassword = confirmPasswordInput.value;

                        if (password !== confirmPassword) {
                            showWarning("Password and Confirm Password do not match");
                            return;
                        }

                        createAdmin();
                    }
                });
            }

            // Search Filter (Debounce)
            if (searchInput) {
                searchInput.addEventListener("input", function () {
                    clearTimeout(searchTimeout);

                    searchTimeout = setTimeout(() => {
                        loadAdmins();
                    }, 500);
                });
            }

            // Status Filter
            if (statusFilter) {
                statusFilter.addEventListener("change", function () {
                    loadAdmins();
                });
            }

            // =========================
            // LOAD ADMINS (API FILTER)
            // =========================
            function loadAdmins() {
                const searchText = searchInput?.value?.trim() || "";
                const selectedStatus = statusFilter?.value || "All";

                const url = `${API_BASE}/api/admins/admins?searchText=${encodeURIComponent(searchText)}&StatusFilter=${encodeURIComponent(selectedStatus)}`;

                console.log("Loading Admins URL:", url);

                tableBody.innerHTML = `
                            <tr>
                                <td colspan="6" class="text-center py-10 text-slate-500 text-sm">
                                    Loading admins...
                                </td>
                            </tr>
                        `;

                fetch(url)
                    .then(response => response.json())
                    .then(data => {

                        console.log("API DATA:", data);

                        if (!data || data.isError || !data.result) {
                            showError(data?.message || "Failed to load admins");
                            tableBody.innerHTML = `
                                        <tr>
                                            <td colspan="6" class="text-center py-10 text-red-500 text-sm">
                                                Failed to load admins
                                            </td>
                                        </tr>
                                    `;
                            return;
                        }

                        allAdmins = data.result.admins || [];
                        const stats = data.result.stats || {};

                        document.getElementById("totalAdmins").innerText = stats.totalAdmins ?? 0;
                        document.getElementById("activeAdmins").innerText = stats.activeAdmins ?? 0;
                        document.getElementById("pendingAdmins").innerText = stats.pendingAdmins ?? 0;

                        renderAdmins(allAdmins);
                    })
                    .catch(error => {
                        console.error("Error loading admins:", error);
                        showError("Error loading admins");
                        tableBody.innerHTML = `
                                    <tr>
                                        <td colspan="6" class="text-center py-10 text-red-500 text-sm">
                                            Error loading admins
                                        </td>
                                    </tr>
                                `;
                    });
            }

            // =========================
            // RENDER ADMINS
            // =========================
            function renderAdmins(admins) {
                tableBody.innerHTML = "";

                if (!admins || admins.length === 0) {
                    tableBody.innerHTML = `
                                <tr>
                                    <td colspan="6" class="text-center py-10 text-slate-500 text-sm">
                                        No admins found
                                    </td>
                                </tr>
                            `;
                    return;
                }

                admins.forEach(admin => {
                    let initials = (admin.fullName || "NA")
                        .split(" ")
                        .map(x => x[0])
                        .join("")
                        .toUpperCase();

                    let statusColor = "emerald";
                    if (admin.status === "Inactive") statusColor = "red";
                    if (admin.status === "Pending") statusColor = "amber";

                    let row = `
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-600 font-bold text-sm">
                                                ${initials}
                                            </div>
                                            <div>
                                                <div class="font-bold text-sm">${admin.fullName ?? '-'}</div>
                                                <div class="text-[11px] text-slate-500 dark:text-slate-400">
                                                    ID: #AD-${admin.adminId ?? '-'}
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-6 py-4 text-sm">${admin.email ?? '-'}</td>

                                    <td class="px-6 py-4 text-sm font-medium text-slate-600 dark:text-slate-300">
                                        ${admin.phone ?? '-'}
                                    </td>

                                    <td class="px-6 py-4 text-sm">
                                        ${admin.companyName ?? '-'}
                                    </td>

                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 bg-${statusColor}-500/10 text-${statusColor}-500 text-[10px] font-bold rounded-full uppercase">
                                            ${admin.status ?? '-'}
                                        </span>
                                    </td>

                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button
                                                class="editAdminBtn p-2 text-slate-400 hover:text-primary hover:bg-primary/5 rounded-lg transition-all"
                                                data-id="${admin.adminId}"
                                                title="Edit Admin">
                                                <span class="material-icons text-sm">edit</span>
                                            </button>

                                            <button
                                                class="deleteAdminBtn p-2 text-slate-400 hover:text-red-500 hover:bg-red-500/5 rounded-lg transition-all"
                                                data-id="${admin.adminId}"
                                                title="Delete Admin">
                                                <span class="material-icons text-sm">delete_outline</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            `;

                    tableBody.innerHTML += row;
                });

                attachRowEvents();
            }

            // =========================
            // ROW EVENTS
            // =========================
            function attachRowEvents() {
                document.querySelectorAll(".editAdminBtn").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const adminId = parseInt(this.getAttribute("data-id"));
                        const selectedAdmin = allAdmins.find(x => x.adminId === adminId);

                        if (selectedAdmin) {
                            setEditMode(selectedAdmin);
                        }
                    });
                });

                document.querySelectorAll(".deleteAdminBtn").forEach(btn => {
                    btn.addEventListener("click", async function () {
                        const adminId = parseInt(this.getAttribute("data-id"));
                        const selectedAdmin = allAdmins.find(x => x.adminId === adminId);

                        const result = await Swal.fire({
                            title: 'Delete Admin?',
                            text: `Are you sure you want to delete ${selectedAdmin?.fullName || 'this admin'}?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#dc2626',
                            cancelButtonColor: '#64748b',
                            confirmButtonText: 'Yes, Delete',
                            zIndex: 30000
                        });

                        if (result.isConfirmed) {
                            deleteAdmin(adminId);
                        }
                    });
                });
            }

            // =========================
            // LOAD COMPANIES
            // =========================
            function loadCompanies() {
                const dropdown = document.getElementById("companyDropdown");
                dropdown.innerHTML = '<option value="">Loading companies...</option>';

                fetch(`${API_BASE}/api/companies/dropdown`)
                    .then(response => response.json())
                    .then(data => {
                        dropdown.innerHTML = '<option value="">Select Company</option>';

                        if (data.result && data.result.length > 0) {
                            data.result.forEach(company => {
                                const option = document.createElement("option");
                                option.value = company.companyId;
                                option.textContent = company.companyName;
                                dropdown.appendChild(option);
                            });
                        }
                    })
                    .catch(error => {
                        console.error("Company API error:", error);
                        dropdown.innerHTML = '<option value="">Failed to load companies</option>';
                    });
            }

            // =========================
            // CREATE ADMIN
            // =========================
            function createAdmin() {
                const companyValue = document.getElementById("companyDropdown").value;

                if (!companyValue) {
                    showWarning("Please select a company");
                    return;
                }

                const data = {
                    fullName: document.getElementById("fullName").value.trim(),
                    username: document.getElementById("username").value.trim(),
                    email: document.getElementById("email").value.trim(),
                    password: passwordInput.value,
                    confirmPassword: confirmPasswordInput.value,
                    phone: document.getElementById("phone").value.trim(),
                    companyId: parseInt(companyValue),
                    createdBy: CREATED_BY
                };

                fetch(`${API_BASE}/api/admins/SignUpAdmin`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(data)
                })
                    .then(response => response.json())
                    .then(result => {
                        console.log("Create Response:", result);

                        if (!result.isError) {
                            closeModal();
                            showSuccess(result.message || "Admin created successfully");
                            loadAdmins();
                        } else {
                            showError(result.message || "Failed to create admin");
                        }
                    })
                    .catch(error => {
                        console.error("Signup error:", error);
                        showError("Something went wrong while creating admin");
                    });
            }

            // =========================
            // UPDATE ADMIN
            // =========================
            function updateAdmin() {
                const companyValue = document.getElementById("companyDropdown").value;

                if (!companyValue) {
                    showWarning("Please select a company");
                    return;
                }

                const data = {
                    adminId: editingAdminId,
                    fullName: document.getElementById("fullName").value.trim(),
                    username: document.getElementById("username").value.trim(),
                    email: document.getElementById("email").value.trim(),
                    phone: document.getElementById("phone").value.trim(),
                    companyId: parseInt(companyValue),
                    modifiedBy: MODIFIED_BY
                };

                fetch(`${API_BASE}/api/admins/admin/update`, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(data)
                })
                    .then(response => response.json())
                    .then(result => {
                        console.log("Update Response:", result);

                        if (!result.isError) {
                            showSuccess(result.message || "Admin updated successfully");
                            loadAdmins();
                        } else {
                            showError(result.message || "Failed to update admin");
                        }
                    })
                    .catch(error => {
                        console.error("Update error:", error);
                        showError("Something went wrong while updating admin");
                    });
            }

            // =========================
            // DELETE ADMIN
            // =========================
            function deleteAdmin(adminId) {
                fetch(`${API_BASE}/api/admins/admin/${adminId}?modifiedBy=${MODIFIED_BY}`, {
                    method: "DELETE"
                })
                    .then(response => response.json())
                    .then(result => {
                        console.log("Delete Response:", result);

                        if (!result.isError) {
                            showSuccess(result.message || "Admin deleted successfully");
                            loadAdmins();
                        } else {
                            showError(result.message || "Failed to delete admin");
                        }
                    })
                    .catch(error => {
                        console.error("Delete error:", error);
                        showError("Something went wrong while deleting admin");
                    });
            }

            // =========================
            // INIT
            // =========================
            loadAdmins();
        });
    </script>
}