                </button>
                <button class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    <span class="material-icons text-sm">file_download</span> Export
                </button>
            </div>
        </div>

        <!-- Data Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead id="tableHeader"></thead>
                <tbody id="tableBody" class="divide-y divide-primary/5"></tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-primary/5 flex items-center justify-between bg-slate-50/30 dark:bg-background-dark/30">
            <p class="text-xs text-slate-500 dark:text-slate-400" id="paginationText">
                Showing <span class="font-semibold text-slate-900 dark:text-white">0</span> records
            </p>
            <div class="flex gap-2">
                <button class="px-3 py-1 text-xs font-bold bg-primary text-white rounded">1</button>
            </div>
        </div>
    </section>

    <!-- Company Stats Visualization -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Trip Performance -->
        <div class="lg:col-span-2 bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm">
            <div class="flex items-center justify-between mb-6">
                <h3 class="font-bold">Trip Performance</h3>
                <select class="bg-transparent border-none text-xs font-semibold text-primary focus:ring-0">
                    <option>This Week</option>
                    <option>Last Month</option>
                </select>
            </div>

            <div class="h-48 flex items-end gap-2 pb-2" id="tripPerformanceChart">
                <!-- Dynamic bars -->
            </div>

            <div class="flex justify-between mt-2 text-[10px] text-slate-500 font-medium uppercase px-1" id="tripPerformanceLabels">
                <!-- Dynamic labels -->
            </div>
        </div>

        <!-- Fleet Distribution -->
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm">
            <h3 class="font-bold mb-6">Fleet Distribution</h3>

            <div class="flex items-center justify-center mb-6">
                <div class="relative w-32 h-32 rounded-full border-[10px] border-slate-100 dark:border-slate-800 flex items-center justify-center">
                    <div class="absolute inset-0 rounded-full border-[10px] border-t-primary border-l-primary border-r-primary border-b-transparent transform rotate-45"></div>
                    <div class="text-center">
                        <span class="block text-xl font-bold" id="fleetTotalVehicles">0</span>
                        <span class="text-[10px] text-slate-500 uppercase">Vehicles</span>
                    </div>
                </div>
            </div>

            <div class="space-y-3">
                <div class="flex items-center justify-between text-xs">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-primary"></span>
                        <span class="text-slate-600 dark:text-slate-400">Large Buses</span>
                    </div>
                    <span class="font-bold" id="fleetLargeBuses">0</span>
                </div>

                <div class="flex items-center justify-between text-xs">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
                        <span class="text-slate-600 dark:text-slate-400">Minivans</span>
                    </div>
                    <span class="font-bold" id="fleetMinivans">0</span>
                </div>

                <div class="flex items-center justify-between text-xs">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-slate-300 dark:bg-slate-700"></span>
                        <span class="text-slate-600 dark:text-slate-400">Maintenance</span>
                    </div>
                    <span class="font-bold" id="fleetMaintenanceBuses">0</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="mt-8">
        <div class="flex flex-col md:flex-row justify-between items-center py-4 px-6 border-t border-slate-200 dark:border-border-dark text-slate-400 text-xs">
            <p>© 2026 OmniBus Platform. All rights reserved.</p>

            <div class="flex items-center gap-4 mt-2 md:mt-0">
                <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
                <span class="opacity-50">|</span>
                <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
                <span class="opacity-50">|</span>
                <a href="#" class="hover:text-primary transition-colors">Support</a>
            </div>
        </div>
    </footer>
</div>

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            const API_BASE = "http://192.168.10.189:8021";
            const companyDetailsApi = `${API_BASE}/api/companies/company-details`;

            let currentView = "students";
            let companyDetailsData = {
                students: [],
                drivers: [],
                buses: [],
                trips: [],
                tripPerformance: [],
                fleet: {},
                fleetGraph: {},
                header: null,
                sidebar: null
            };

            // =========================
            // Helpers
            // =========================
            function showError(message) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: message,
                    confirmButtonColor: '#dc2626',
                    zIndex: 30000
                });
            }

            function getQueryParam(name) {
                const urlParams = new URLSearchParams(window.location.search);
                return urlParams.get(name);
            }

            function formatDate(dateStr) {
                if (!dateStr) return "N/A";
                const date = new Date(dateStr);
                if (isNaN(date)) return "N/A";
                return date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                });
            }

            function getInitials(name) {
                if (!name || name === "Unknown" || name === "N/A") return "NA";
                return name
                    .split(" ")
                    .map(word => word[0])
                    .join("")
                    .substring(0, 2)
                    .toUpperCase();
            }

            function getStatusBadge(status) {
                const s = (status || "").toLowerCase();

                if (s.includes("active") || s.includes("completed") || s.includes("on duty")) {
                    return `<span class="px-2.5 py-1 bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded-full uppercase">${status}</span>`;
                }

                if (s.includes("maintenance") || s.includes("break") || s.includes("scheduled")) {
                    return `<span class="px-2.5 py-1 bg-amber-500/10 text-amber-500 text-[10px] font-bold rounded-full uppercase">${status}</span>`;
                }

                if (s.includes("inactive") || s.includes("suspended") || s.includes("cancelled")) {
                    return `<span class="px-2.5 py-1 bg-red-500/10 text-red-500 text-[10px] font-bold rounded-full uppercase">${status}</span>`;
                }

                return `<span class="px-2.5 py-1 bg-slate-500/10 text-slate-500 text-[10px] font-bold rounded-full uppercase">${status || "N/A"}</span>`;
            }

            // =========================
            // Company ID
            // =========================
            // const companyId = getQueryParam("companyId") || window.location.pathname.split("/").pop();
            const companyId = 1;

            if (!companyId || isNaN(companyId)) {
                showError("Invalid Company ID.");
                return;
            }

            // =========================
            // Fetch Company Details
            // =========================
            async function loadCompanyDetails() {
                try {
                    console.log("companyId", companyId);
                    const response = await fetch(`${companyDetailsApi}?companyId=${companyId}`);
                    const data = await response.json();

                    if (!response.ok || data.isError) {
                        throw new Error(data?.message || "Failed to fetch company details");
                    }

                    companyDetailsData = data.result || {};
                    console.log("Company Details:", companyDetailsData);

                    renderDashboard(companyDetailsData);
                    switchView("students");

                    document.getElementById("lastUpdatedText").textContent =
                        `Last updated: ${new Date().toLocaleString()}`;

                } catch (error) {
                    console.error("Company Details Error:", error);
                    showError(error.message || "Failed to load company details.");
                }
            }

            // =========================
            // Dashboard Render
            // =========================
            function renderDashboard(data) {
                const header = data.header || {};
                const sidebar = data.sidebar || {};
                const students = data.students || [];
                const drivers = data.drivers || [];
                const buses = data.buses || [];
                const trips = data.trips || [];
                const fleet = data.fleet || {};

                // Header title
                document.getElementById("companyTitle").textContent =
                    header.companyName || sidebar.companyName || "Company Details";

                // Summary cards
                document.getElementById("totalStudentsCard").textContent = students.length || 0;
                document.getElementById("totalDriversCard").textContent = drivers.length || 0;
                document.getElementById("totalBusesCard").textContent = buses.length || 0;
                document.getElementById("totalTripsCard").textContent = trips.length || 0;

                // Company Information
                document.getElementById("infoCompanyName").textContent =
                    header.companyName || sidebar.companyName || "N/A";

                document.getElementById("infoCompanyEmail").textContent =
                    header.companyEmail || sidebar.companyEmail || "N/A";

                document.getElementById("infoCompanyCode").textContent =
                    header.companyCode || sidebar.companyCode || `COMP-${companyId}`;

                document.getElementById("infoLocation").textContent =
                    `${header.city || sidebar.city || "N/A"}, ${header.country || sidebar.country || "N/A"}`;

                document.getElementById("infoStudents").textContent = students.length || 0;
                document.getElementById("infoDrivers").textContent = drivers.length || 0;
                document.getElementById("infoBuses").textContent = buses.length || 0;
                document.getElementById("infoTrips").textContent = trips.length || 0;

                // Status badge
                const isActive = (header.isActive ?? sidebar.isActive ?? true);
                const statusBadge = document.getElementById("companyStatusBadge");

                if (isActive) {
                    statusBadge.className = "px-3 py-1 bg-emerald-500/10 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/20 flex items-center";
                    statusBadge.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-2"></span> ACTIVE`;
                } else {
                    statusBadge.className = "px-3 py-1 bg-slate-500/10 text-slate-500 text-xs font-bold rounded-full border border-slate-500/20 flex items-center";
                    statusBadge.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-slate-500 mr-2"></span> INACTIVE`;
                }

                // Fleet Distribution
                document.getElementById("fleetTotalVehicles").textContent = fleet.totalVehicles || 0;
                document.getElementById("fleetLargeBuses").textContent = fleet.largeBuses || 0;
                document.getElementById("fleetMinivans").textContent = fleet.minivans || 0;
                document.getElementById("fleetMaintenanceBuses").textContent = fleet.maintenanceBuses || 0;

                // Trip Performance
                renderTripPerformance(data.tripPerformance || []);
            }

            // =========================
            // Trip Performance Render
            // =========================
            function renderTripPerformance(tripPerformance) {
                const chartContainer = document.getElementById("tripPerformanceChart");
                const labelsContainer = document.getElementById("tripPerformanceLabels");

                if (!tripPerformance || tripPerformance.length === 0) {
                    chartContainer.innerHTML = `
                                <div class="w-full h-full flex items-center justify-center text-slate-400 text-sm">
                                    No trip performance data available
                                </div>
                            `;
                    labelsContainer.innerHTML = "";
                    return;
                }

                const maxTrips = Math.max(...tripPerformance.map(x => x.totalTrips || 0), 1);

                chartContainer.innerHTML = tripPerformance.map(item => {
                    const heightPercent = Math.max(((item.totalTrips || 0) / maxTrips) * 100, 10);
                    return `
                                <div class="flex-1 bg-primary/20 rounded-t relative group" style="height:${heightPercent}%">
                                    <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">
                                        ${item.totalTrips || 0}
                                    </div>
                                </div>
                            `;
                }).join("");

                labelsContainer.innerHTML = tripPerformance.map(item => {
                    return `<span>${item.dayName || "N/A"}</span>`;
                }).join("");
            }

            // =========================
            // Table Data Builders
            // =========================
            function getStudentsTableData() {
                const students = companyDetailsData.students || [];

                return {
                    header: `
                                <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                    <th class="px-6 py-4">Student Info</th>
                                    <th class="px-6 py-4">Student ID</th>
                                    <th class="px-6 py-4">Route Name</th>
                                    <th class="px-6 py-4">Parent Contact</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            `,
                    body: students.length > 0 ? students.map(student => `
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-xs">
                                                ${getInitials(student.studentName)}
                                            </div>
                                            <div>
                                                <div class="font-semibold text-sm">${student.studentName || "N/A"}</div>
                                                <div class="text-xs text-slate-500 dark:text-slate-400">${student.grade || "N/A"}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${student.studentCode || student.studentId || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-medium text-primary">${student.routeName || "Not Assigned"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${student.parentName || "N/A"}</div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400">${student.parentPhone || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        ${getStatusBadge(student.status || "Active")}
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary transition-colors">
                                            <span class="material-icons">more_vert</span>
                                        </button>
                                    </td>
                                </tr>
                            `).join("") : `
                                <tr>
                                    <td colspan="6" class="px-6 py-10 text-center text-slate-500">
                                        No students found.
                                    </td>
                                </tr>
                            `,
                    searchPlaceholder: "Search students by name, ID or route...",
                    paginationLabel: "students",
                    count: students.length
                };
            }

            function getDriversTableData() {
                const drivers = companyDetailsData.drivers || [];

                return {
                    header: `
                                <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                    <th class="px-6 py-4">Driver Info</th>
                                    <th class="px-6 py-4">License / ID</th>
                                    <th class="px-6 py-4">Assigned Bus</th>
                                    <th class="px-6 py-4">Experience</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            `,
                    body: drivers.length > 0 ? drivers.map(driver => `
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-amber-500/20 flex items-center justify-center text-amber-500 font-bold text-xs">
                                                ${getInitials(driver.driverName)}
                                            </div>
                                            <div>
                                                <div class="font-semibold text-sm">${driver.driverName || "N/A"}</div>
                                                <div class="text-xs text-slate-500 dark:text-slate-400">${driver.phoneNumber || "N/A"}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${driver.licenseNumber || "N/A"}</div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400">${driver.driverCode || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-medium text-primary">${driver.busNumber || "Not Assigned"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${driver.experience || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        ${getStatusBadge(driver.status || "Active")}
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary transition-colors">
                                            <span class="material-icons">more_vert</span>
                                        </button>
                                    </td>
                                </tr>
                            `).join("") : `
                                <tr>
                                    <td colspan="6" class="px-6 py-10 text-center text-slate-500">
                                        No drivers found.
                                    </td>
                                </tr>
                            `,
                    searchPlaceholder: "Search drivers by name, ID or license...",
                    paginationLabel: "drivers",
                    count: drivers.length
                };
            }

            function getBusesTableData() {
                const buses = companyDetailsData.buses || [];

                return {
                    header: `
                                <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                    <th class="px-6 py-4">Bus Details</th>
                                    <th class="px-6 py-4">Plate Number</th>
                                    <th class="px-6 py-4">Assigned Driver</th>
                                    <th class="px-6 py-4">Capacity</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            `,
                    body: buses.length > 0 ? buses.map(bus => `
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-xs">
                                                ${bus.busNumber || "NA"}
                                            </div>
                                            <div>
                                                <div class="font-semibold text-sm">Bus #${bus.busNumber || "N/A"}</div>
                                                <div class="text-xs text-slate-500 dark:text-slate-400">Fleet Vehicle</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${bus.plateNumber || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-medium text-primary">${bus.driverName || "Not Assigned"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${bus.capacity || 0} Seats</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        ${getStatusBadge(bus.status || "N/A")}
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary transition-colors">
                                            <span class="material-icons">more_vert</span>
                                        </button>
                                    </td>
                                </tr>
                            `).join("") : `
                                <tr>
                                    <td colspan="6" class="px-6 py-10 text-center text-slate-500">
                                        No buses found.
                                    </td>
                                </tr>
                            `,
                    searchPlaceholder: "Search buses by number, plate or driver...",
                    paginationLabel: "buses",
                    count: buses.length
                };
            }

            function getTripsTableData() {
                const trips = companyDetailsData.trips || [];

                return {
                    header: `
                                <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                                    <th class="px-6 py-4">Trip Info</th>
                                    <th class="px-6 py-4">Route Name</th>
                                    <th class="px-6 py-4">Driver & Bus</th>
                                    <th class="px-6 py-4">Timing</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            `,
                    body: trips.length > 0 ? trips.map(trip => `
                                <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-500 font-bold text-xs">
                                                TR
                                            </div>
                                            <div>
                                                <div class="font-semibold text-sm">#TR-${trip.tripId || "N/A"}</div>
                                                <div class="text-xs text-slate-500 dark:text-slate-400">${formatDate(trip.tripDate)}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-medium text-primary">${trip.routeName || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-semibold">${trip.driverName || "Unknown"}</div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400">Bus #${trip.busNumber || "N/A"}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="text-sm">${trip.startTimeFormatted || "N/A"} - ${trip.endTimeFormatted || "N/A"}</div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400">${formatDate(trip.tripDate)}</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        ${getStatusBadge(trip.tripStatus || "N/A")}
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="text-slate-400 hover:text-primary transition-colors">
                                            <span class="material-icons">more_vert</span>
                                        </button>
                                    </td>
                                </tr>
                            `).join("") : `
                                <tr>
                                    <td colspan="6" class="px-6 py-10 text-center text-slate-500">
                                        No trips found.
                                    </td>
                                </tr>
                            `,
                    searchPlaceholder: "Search trips by ID, route or driver...",
                    paginationLabel: "trips",
                    count: trips.length
                };
            }

            // =========================
            // Switch View
            // =========================
            window.switchView = function (view) {
                currentView = view;

                let data = null;

                if (view === "students") data = getStudentsTableData();
                if (view === "drivers") data = getDriversTableData();
                if (view === "buses") data = getBusesTableData();
                if (view === "trips") data = getTripsTableData();

                if (!data) return;

                // Tabs styling
                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'active');
                    btn.classList.add('text-slate-500', 'dark:text-slate-400', 'font-medium');
                });

                const activeBtn = document.querySelector(`.tab-btn[data-view="${view}"]`);
                if (activeBtn) {
                    activeBtn.classList.remove('text-slate-500', 'dark:text-slate-400', 'font-medium');
                    activeBtn.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'active');
                }

                document.getElementById("tableHeader").innerHTML = data.header;
                document.getElementById("tableBody").innerHTML = data.body;
                document.getElementById("viewSearchInput").placeholder = data.searchPlaceholder;
                document.getElementById("paginationText").innerHTML =
                    `Showing <span class="font-semibold text-slate-900 dark:text-white">${data.count}</span> ${data.paginationLabel}`;
            };

            // =========================
            // Search Filter
            // =========================
            document.getElementById("viewSearchInput").addEventListener("input", function () {
                const search = this.value.toLowerCase().trim();
                let rows = document.querySelectorAll("#tableBody tr");

                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(search) ? "" : "none";
                });
            });

            // =========================
            // Init
            // =========================
            await loadCompanyDetails();
        });
    </script>
}