        function switchView(view) {
            if (!tableData[view]) return;

            const data = tableData[view];

            // Update Tabs styling
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'active');
                btn.classList.add('text-slate-500', 'dark:text-slate-400', 'font-medium');
            });

            const activeBtn = document.querySelector(`.tab-btn[data-view="${view}"]`);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-500', 'dark:text-slate-400', 'font-medium');
                activeBtn.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'active');
            }

            // Update Table Header and Body
            document.getElementById('tableHeader').innerHTML = data.header;
            document.getElementById('tableBody').innerHTML = data.body;

            // Update Search Placeholder
            document.getElementById('viewSearchInput').placeholder = data.searchPlaceholder;

            // Update Pagination Text (Simplified for demo)
            const count = data.count;
            const label = data.paginationLabel;
            document.getElementById('paginationText').innerHTML = `Showing <span class="font-semibold text-slate-900 dark:text-white">1</span> to <span class="font-semibold text-slate-900 dark:text-white">${view === 'students' ? '4' : '2'}</span> of <span class="font-semibold text-slate-900 dark:text-white">${count}</span> ${label}`;
