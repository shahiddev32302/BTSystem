@{
    ViewData["Title"] = "Company Management";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="flex-1 overflow-y-auto p-8 space-y-8">
    <!-- Welcome Section -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight">Company Management</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">
                Manage and monitor all registered bus
                transportation companies.
            </p>
        </div>
        <div class="flex items-center gap-3">
            <button id="addCompanyBtn"
                    class="flex items-center gap-3 px-5 py-2.5 bg-primary text-white hover:bg-primary/90 rounded-xl transition-all text-sm font-semibold shadow-lg shadow-primary/25">
                <span class="material-icons text-[20px]">add</span>
                Add New Company
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Companies -->
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        Total
                        Companies
                    </p>
                    <h3 class="text-2xl font-bold mt-1">128</h3>
                    <p class="text-emerald-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">trending_up</span> +4 this month
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">business</span>
                </div>
            </div>
        </div>
        <!-- Active Companies -->
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        Active
                        Status
                    </p>
                    <h3 class="text-2xl font-bold mt-1">114</h3>
                    <p class="text-emerald-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">check_circle</span> 89% overall
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">verified</span>
                </div>
            </div>
        </div>
        <!-- Monthly Trips -->
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        Avg.
                        Trips/Co
                    </p>
                    <h3 class="text-2xl font-bold mt-1">332</h3>
                    <p class="text-primary text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">route</span> 42.5k total
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">moving</span>
                </div>
            </div>
        </div>
        <!-- Total Students -->
        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-primary/5 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">
                        Total
                        Students
                    </p>
                    <h3 class="text-2xl font-bold mt-1">8.2k</h3>
                    <p class="text-indigo-500 text-xs font-medium mt-2 flex items-center">
                        <span class="material-icons text-sm mr-1">school</span> Across all fleet
                    </p>
                </div>
                <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-icons text-primary group-hover:text-white">groups</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter and Search Bar -->
    <div class="bg-white dark:bg-surface-dark p-4 rounded-xl border border-primary/5 shadow-sm flex flex-col sm:flex-row gap-4 justify-between items-center bg-slate-50/50 dark:bg-background-dark/30">
        <div class="relative w-full sm:w-96">
            <span class="material-icons absolute left-3 top-2.5 text-slate-400 text-sm">search</span>
            <input class="w-full bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-transparent"
                   placeholder="Search companies by name, admin or ID..." type="text" />
        </div>
        <div class="flex gap-2 w-full sm:w-auto">
            <select class="bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none cursor-pointer">
                <option>Status: All</option>
                <option>Active Only</option>
                <option>Inactive Only</option>
            </select>
            <button class="flex items-center justify-center gap-2 px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                <span class="material-icons text-sm">filter_list</span>
            </button>
        </div>
    </div>

    <!-- Companies Table -->
    <div class="bg-white dark:bg-surface-dark rounded-xl border border-primary/5 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-background-dark/50 text-slate-500 dark:text-slate-400 text-[11px] font-bold uppercase tracking-wider">
                        <th class="px-6 py-4">Company Info</th>
                        <th class="px-6 py-4">Admin Body</th>
                        <th class="px-6 py-4 text-center">Buses</th>
                        <th class="px-6 py-4 text-center">Students</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-primary/5">
                    <!-- Row 1 -->
                    <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">
                                    CT
                                </div>
                                <div>
                                    <a asp-controller="Company" asp-action="Details"
                                       class="font-bold text-sm hover:text-primary transition-colors cursor-pointer">
                                        City Transit
                                        Group
                                    </a>
                                    <div class="text-[11px] text-slate-500 dark:text-slate-400">ID: #CO-99212</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm font-medium">John Smith</div>
                            <div class="text-xs text-slate-500 dark:text-slate-400">jsmith@citytransit.com</div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-primary text-[14px]">directions_bus</span>
                                <span class="text-sm font-bold">420</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-indigo-500 text-[14px]">school</span>
                                <span class="text-sm font-bold">12.5k</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded-full uppercase">Active</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <a href="CompanyDetails.html"
                                   class="p-2 text-slate-400 hover:text-primary hover:bg-primary/5 rounded-lg transition-all"
                                   title="View Details">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <button class="p-2 text-slate-400 hover:text-amber-500 hover:bg-amber-500/5 rounded-lg transition-all"
                                        title="Edit Company">
                                    <span class="material-icons text-sm">edit</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500 font-bold text-sm">
                                    US
                                </div>
                                <div>
                                    <a asp-controller="Company" asp-action="Details"
                                       class="font-bold text-sm hover:text-primary transition-colors cursor-pointer">
                                        Unified Schools
                                        Network
                                    </a>
                                    <div class="text-[11px] text-slate-500 dark:text-slate-400">ID: #CO-88410</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm font-medium">Sarah Johnson</div>
                            <div class="text-xs text-slate-500 dark:text-slate-400">s.johnson@unified.edu</div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-primary text-[14px]">directions_bus</span>
                                <span class="text-sm font-bold">385</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-indigo-500 text-[14px]">school</span>
                                <span class="text-sm font-bold">10.2k</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 bg-emerald-500/10 text-emerald-500 text-[10px] font-bold rounded-full uppercase">Active</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <a href="CompanyDetails.html"
                                   class="p-2 text-slate-400 hover:text-primary hover:bg-primary/5 rounded-lg transition-all"
                                   title="View Details">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <button class="p-2 text-slate-400 hover:text-amber-500 hover:bg-amber-500/5 rounded-lg transition-all"
                                        title="Edit Company">
                                    <span class="material-icons text-sm">edit</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 3 -->
                    <tr class="hover:bg-slate-50/50 dark:hover:bg-primary/5 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-slate-500/10 flex items-center justify-center text-slate-500 font-bold text-sm">
                                    GL
                                </div>
                                <div>
                                    <a asp-controller="Company" asp-action="Details"
                                       class="font-bold text-sm hover:text-primary transition-colors cursor-pointer">
                                        Global Logistics
                                        Corp
                                    </a>
                                    <div class="text-[11px] text-slate-500 dark:text-slate-400">ID: #CO-22104</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm font-medium">Mike Chen</div>
                            <div class="text-xs text-slate-500 dark:text-slate-400">m.chen@glcorp.com</div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-primary text-[14px]">directions_bus</span>
                                <span class="text-sm font-bold">210</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 dark:bg-slate-800 rounded-full border border-slate-100 dark:border-slate-700">
                                <span class="material-icons text-indigo-500 text-[14px]">school</span>
                                <span class="text-sm font-bold">5.8k</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 bg-slate-500/10 text-slate-500 text-[10px] font-bold rounded-full uppercase">Inactive</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <a href="CompanyDetails.html"
                                   class="p-2 text-slate-400 hover:text-primary hover:bg-primary/5 rounded-lg transition-all"
                                   title="View Details">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <button class="p-2 text-slate-400 hover:text-amber-500 hover:bg-amber-500/5 rounded-lg transition-all"
                                        title="Edit Company">
                                    <span class="material-icons text-sm">edit</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <!-- ➕ Add Company Modal -->
    <div id="addCompanyModal" class="fixed inset-0 z-[9999] hidden">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" id="modalBackdrop"></div>

        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative w-full max-w-lg overflow-hidden rounded-2xl bg-white dark:bg-surface-dark p-8 shadow-2xl border border-slate-200 dark:border-border-dark">

                <!-- Header -->
                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                            <span class="material-icons text-primary">business</span>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold">Add New Company</h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                                Register a new tenant in the system
                            </p>
                        </div>
                    </div>

                    <button id="closeModalBtn"
                            class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                        <span class="material-icons">close</span>
                    </button>
                </div>

                <!-- Form -->
                <form id="addCompanyForm" class="space-y-6">

                    <div>
                        <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">
                            Company Name
                        </label>

                        <div class="relative">
                            <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">business</span>

                            <input type="text" required
                                   class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none text-sm"
                                   placeholder="e.g. City Transit Group">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">
                                Admin Full Name
                            </label>

                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">person</span>

                                <input type="text" required
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none text-sm"
                                       placeholder="John Doe">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">
                                Contact Email
                            </label>

                            <div class="relative">
                                <span class="material-icons absolute left-4 top-3.5 text-slate-400 text-[18px]">email</span>

                                <input type="email" required
                                       class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none text-sm"
                                       placeholder="admin@company.com">
                            </div>
                        </div>

                    </div>

                    <!-- Buttons -->
                    <div class="mt-8 flex flex-col sm:flex-row gap-3 pt-6 border-t border-slate-100 dark:border-border-dark">

                        <button type="button" id="cancelModalBtn"
                                class="flex-1 px-6 py-3 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-bold rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 text-sm">
                            Cancel
                        </button>

                        <button type="submit"
                                class="flex-1 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 shadow-lg shadow-primary/25 text-sm flex items-center justify-center gap-2">
                            <span class="material-icons text-sm">check_circle</span>
                            Confirm & Create
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
    <!-- Footer -->
    <div class="flex flex-col md:flex-row justify-between items-center py-4 border-t border-slate-200 dark:border-border-dark text-slate-400 text-xs">
        <p>© 2024 OmniBus Tracking System. All rights reserved.</p>
        <div class="flex gap-6 mt-4 md:mt-0">
            <a class="hover:text-primary transition-colors" href="#">Privacy Policy</a>
            <a class="hover:text-primary transition-colors" href="#">Service Status</a>
            <a class="hover:text-primary transition-colors" href="#">API Docs</a>
        </div>
    </div>
</div>


@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const modal = document.getElementById("addCompanyModal");
            const openBtn = document.getElementById("addCompanyBtn");
            const closeBtn = document.getElementById("closeModalBtn");
            const cancelBtn = document.getElementById("cancelModalBtn");
            const backdrop = document.getElementById("modalBackdrop");
            const form = document.getElementById("addCompanyForm");

            function openModal() {
                modal.classList.remove("hidden");
            }

            function closeModal() {
                modal.classList.add("hidden");
            }

            openBtn.addEventListener("click", openModal);
            closeBtn.addEventListener("click", closeModal);
            cancelBtn.addEventListener("click", closeModal);
            backdrop.addEventListener("click", closeModal);

            form.addEventListener("submit", function (e) {
                e.preventDefault();

                alert("Company Created Successfully!");

                form.reset();
                closeModal();
            });

        });
    </script>

}